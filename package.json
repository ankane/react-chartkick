{
  "name": "react-chartkick",
  "version": "0.5.4",
  "description": "Create beautiful JavaScript charts with one line of React",
  "homepage": "https://github.com/ankane/react-chartkick",
  "license": "MIT",
  "author": "Andrew Kane",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/react-chartkick.js",
  "module": "./dist/react-chartkick.esm.js",
  "exports": {
    ".": {
      "require": "./dist/react-chartkick.js",
      "import": "./dist/react-chartkick.esm.js"
    }
  },
  "dependencies": {
    "chartkick": ">=4.0.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.18.9",
    "@rollup/plugin-buble": "^1.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.25.0"
  },
  "scripts": {
    "build": "rollup -c"
  }
}
